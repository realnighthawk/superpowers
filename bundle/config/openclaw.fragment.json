  "bindings": [
    {
      "agentId": "assistant",
      "match": {
        "channel": "discord"
      }
    }
  ],
  "plugins": {
    "allow": [
      "nighthawk-superpowers",
      "discord",
      "google",
      "openai",
      "memory-core",
      "lossless-claw",
      "diagnostics-otel",
      "youtube-transcripts"
    ],
    "entries": {
      "nighthawk-superpowers": {
        "enabled": true
      },
      "discord": {
        "enabled": true
      },
      "google": {
        "enabled": true
      },
      "openai": {
        "enabled": true
      },
      "memory-core": {
        "enabled": true,
        "config": {
          "dreaming": {
            "enabled": true,
            "frequency": "0 3 * * *",
            "model": "google/gemini-3-flash-preview"
          }
        }
      },
      "lossless-claw": {
        "enabled": true
      },
      "diagnostics-otel": {
        "enabled": true
      },
      "youtube-transcripts": {
        "enabled": true
      }
    },
    "slots": {
      "memory": "memory-core",
      "contextEngine": "lossless-claw"
    }
  },
  "commands": {
    "ownerAllowFrom": [
      "discord:REPLACE_DISCORD_USER_ID"
    ]
  },
  "mcp": {
    "servers": {
      "exa": {
        "command": "npx",
        "args": [
          "-y",
          "mcp-remote@0.1.16",
          "https://mcp.exa.ai/mcp",
          "--header",
          "x-api-key:${EXA_API_KEY}"
        ]
      },
      "google-maps": {
        "command": "npx",
        "args": [
          "-y",
          "@cablate/mcp-google-map",
          "--stdio"
        ],
        "env": {
          "GOOGLE_MAPS_API_KEY": "${GOOGLE_PLACES_API_KEY}"
        }
      }
    }
  },
  "skills": {
    "entries": {
      "goplaces": {
        "apiKey": {
          "source": "env",
          "provider": "default",
          "id": "GOOGLE_PLACES_API_KEY"
        }
      }
    }
  }
}
