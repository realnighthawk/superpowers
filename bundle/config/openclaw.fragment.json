{
  "_comment": "Merge into openclaw.json. Replace all REPLACE_* tokens. Enable companion plugins separately. Note: k8s-debug skill is provided by OpenClaw install, not this bundle.",
  "browser": {
    "ssrfPolicy": {
      "dangerouslyAllowPrivateNetwork": true
    }
  },
  "auth": {
    "profiles": {
      "google:free": {
        "type": "api_key",
        "provider": "google",
        "keyRef": {
          "source": "env",
          "provider": "default",
          "id": "GEMINI_API_KEY"
        }
      },
      "google:paid": {
        "type": "api_key",
        "provider": "google",
        "keyRef": {
          "source": "env",
          "provider": "default",
          "id": "GEMINI_API_KEY_PAID"
        }
      },
      "openai:default": {
        "type": "api_key",
        "provider": "openai",
        "keyRef": {
          "source": "env",
          "provider": "default",
          "id": "LITELLM_API_KEY"
        }
      }
    },
    "order": {
      "google": [
        "google:free",
        "google:paid"
      ]
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "google/gemini-3-flash-preview"
      },
      "imageGenerationModel": {
        "primary": "google/gemini-2.5-flash-image",
        "timeoutMs": 180000
      },
      "mediaGenerationAutoProviderFallback": false,
      "startupContext": {
        "enabled": true,
        "dailyMemoryDays": 3,
        "maxFileChars": 2000,
        "maxTotalChars": 4000
      }
    },
    "list": [
      {
        "id": "assistant",
        "default": true,
        "name": "Assistant",
        "workspace": "REPLACE_STATE_DIR/agents/assistant/workspace",
        "agentDir": "REPLACE_STATE_DIR/agents/assistant/agent",
        "model": "google/gemini-3-flash-preview",
        "skills": [
          "delegate-routing",
          "gog",
          "assistant-personal",
          "discord",
          "discord-post",
          "calendar-block",
          "gmail-action",
          "audio-transcribe",
          "tts-respond",
          "memory-search",
          "web-search",
          "summarize",
          "reminder-check"
        ],
        "tools": {
          "profile": "minimal",
          "alsoAllow": [
            "memory_search",
            "memory_get",
            "sessions_spawn",
            "sessions_list",
            "agents_list",
            "session_status",
            "user_profile_get",
            "user_profile_update",
            "agent_config_get",
            "agent_config_set",
            "message",
            "exec",
            "process",
            "image_generate",
            "image",
            "memory_write"
          ],
          "deny": [
            "write",
            "edit",
            "apply_patch",
            "browser"
          ],
          "exec": {
            "security": "allowlist",
            "ask": "on-miss"
          }
        },
        "subagents": {
          "allowAgents": [
            "assistant",
            "fitness-coach",
            "productivity-agent",
            "finance-agent",
            "creative-agent",
            "learning-agent",
            "sysadmin-agent",
            "social-agent",
            "navigator-agent"
          ],
          "delegationMode": "prefer"
        },
        "identity": {
          "name": "Assistant",
          "emoji": "\ud83e\udd89",
          "theme": "Personal coordinator and Discord steward"
