# Copy to ~/.openclaw/.env and fill in values.

OPENCLAW_GATEWAY_TOKEN=
DISCORD_BOT_TOKEN=

# LiteLLM proxy (chat, embeddings, Whisper STT, Kokoro TTS, stable-diffusion)
LITELLM_API_KEY=
# LITELLM_BASE_URL=http://127.0.0.1:4000/v1

# Gemini chat (google:free) and quota fallback (google:paid)
GEMINI_API_KEY=
GEMINI_API_KEY_PAID=
GOOGLE_API_KEY=

# gog skill (optional)
GOG_KEYRING_PASSWORD=
GOG_ACCOUNT=
GOG_CALENDAR_ID=
